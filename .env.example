HOST=127.0.0.1
PORT=4100
OIDC_ISSUER=http://127.0.0.1:4100
OIDC_DEFAULT_AUDIENCE=local-api
# Multiple audiences supported via comma-separated values:
# OIDC_DEFAULT_AUDIENCE=local-api,other-api
OIDC_CLIENT_ID=local-client
OIDC_CLIENT_SECRET=local-secret
OIDC_REDIRECT_URI=http://127.0.0.1:4100/ui/callback
# Default is intentionally very long (10 years) for local testing.
OIDC_TOKEN_TTL_SECONDS=315360000
